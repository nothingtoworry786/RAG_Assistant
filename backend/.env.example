NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/embeddings
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# HTTPS API (used by this backend). Project URL from Supabase → Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role secret (JWT) from Supabase → Settings → API. NOT the database password.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: if you only copied the "Connection string" (URI) from Supabase → Settings → Database,
# you can put it here under DATABASE_URL. We infer SUPABASE_URL from host db.<ref>.supabase.co.
# You still must set SUPABASE_SERVICE_ROLE_KEY from the API page (not [YOUR-PASSWORD]).
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
PORT=5000
